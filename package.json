{
  "name": "yanluzhongtai",
  "private": true,
  "version": "1.3.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @yanlu/web dev",
    "dev:api": "pnpm --filter @yanlu/api start:dev",
    "debug:api": "pnpm --filter @yanlu/api start:debug",
    "build": "pnpm -r build",
    "prisma:generate": "pnpm --filter @yanlu/api prisma:generate",
    "prisma:push": "pnpm --filter @yanlu/api prisma:push",
    "prisma:seed": "pnpm --filter @yanlu/api prisma:seed",
    "compose:up": "docker compose up --build -d",
    "compose:down": "docker compose down"
  }
}

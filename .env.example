COMPOSE_PROJECT_NAME=yanluzhongtai

WEB_PORT=80
API_PORT=3000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

APP_ORIGIN=http://localhost

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
REFRESH_COOKIE_NAME=yanlu_rt

# 仅用于首次部署创建管理员账号；创建成功后可删除这三行
SEED_SUPER_ADMIN_PHONE=13800000000
SEED_SUPER_ADMIN_USERNAME=超级管理员
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password

POSTGRES_DB=yanluzhongtai
POSTGRES_USER=yanlu
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://yanlu:replace-with-a-strong-password@db:5432/yanluzhongtai?schema=public

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-a-strong-password
MINIO_BUCKET=yanlu-assets
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# 浏览器可访问的 MinIO 地址（用于生成预签名上传/下载 URL）
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

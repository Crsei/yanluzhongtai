NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
REFRESH_COOKIE_NAME=yanlu_rt

# 仅用于首次部署创建管理员账号；创建成功后可删除这三行
SEED_SUPER_ADMIN_PHONE=13800000000
SEED_SUPER_ADMIN_USERNAME=超级管理员
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password

DATABASE_URL=postgresql://yanlu:replace-with-a-strong-password@localhost:5432/yanluzhongtai?schema=public

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-a-strong-password
MINIO_BUCKET=yanlu-assets
# 可选：当浏览器无法直接访问 MINIO_ENDPOINT 时（Docker 内部 hostname），
# 设置为浏览器可访问的 MinIO 地址，用于生成预签名上传/下载 URL
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000
